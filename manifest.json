{
  "manifest_version": 3,
  "name": "OpenModHeader — Modify HTTP Headers",
  "version": "0.0.1",
  "description": "Open-source, transparent HTTP request/response header modifier. No tracking, no external servers.",
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenHeader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
